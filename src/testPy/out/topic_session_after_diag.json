    "diagnostic": {
      "quiz_id": "diag_intro_c_pointers_v1",
      "questions": [
        {
          "question_id": "d1",
          "subskill_id": "c_ptr_address_of",
          "type": "mcq",
          "difficulty": 1,
          "prompt": "What does the expression `&x` evaluate to?",
          "choices": [
            "The value stored in x",
            "The address of x",
            "A copy of x",
            "The size of x"
          ],
          "correct_answer": "The address of x",
          "rubric": [
            "Identifies & as the address-of operator"
          ]
        },
        {
          "question_id": "d2",
          "subskill_id": "c_ptr_address_of",
          "type": "mcq",
          "difficulty": 1,
          "prompt": "Why does `scanf(\"%d\", &x)` use `&x`?",
          "choices": [
            "scanf needs the value of x to compare input",
            "scanf needs a place in memory to store the input",
            "scanf converts x into an integer",
            "scanf returns the address of x"
          ],
          "correct_answer": "scanf needs a place in memory to store the input",
          "rubric": [
            "Mentions scanf writes to the address provided"
          ]
        },
        {
          "question_id": "d3",
          "subskill_id": "c_ptr_declare_types",
          "type": "mcq",
          "difficulty": 1,
          "prompt": "In `int *p, q;` what are the types of p and q?",
          "choices": [
            "p: int, q: int",
            "p: int*, q: int",
            "p: int, q: int*",
            "p: int*, q: int*"
          ],
          "correct_answer": "p: int*, q: int",
          "rubric": [
            "Understands * binds to the declarator and does not distribute"
          ]
        },
        {
          "question_id": "d4",
          "subskill_id": "c_ptr_declare_types",
          "type": "mcq",
          "difficulty": 1,
          "prompt": "Which correctly declares both p and q as pointers to int?",
          "choices": [
            "int *p, q;",
            "int *p, *q;",
            "int p*, q*;",
            "int *(p, q);"
          ],
          "correct_answer": "int *p, *q;",
          "rubric": [
            "Knows correct pointer declaration syntax"
          ]
        },
        {
          "question_id": "d5",
          "subskill_id": "c_ptr_assign_deref",
          "type": "mcq",
          "difficulty": 2,
          "prompt": "Given `int x = 5; int *p = &x;` what does `*p` evaluate to?",
          "choices": [
            "The address of x",
            "The value of x",
            "The size of x",
            "An invalid value"
          ],
          "correct_answer": "The value of x",
          "rubric": [
            "Understands dereference returns the value stored at the address"
          ]
        },
        {
          "question_id": "d6",
          "subskill_id": "c_ptr_assign_deref",
          "type": "mcq",
          "difficulty": 2,
          "prompt": "Given `int x = 5; int *p = &x; *p = 10;` what is x afterward?",
          "choices": [
            "5",
            "10",
            "Undefined",
            "Address of x"
          ],
          "correct_answer": "10",
          "rubric": [
            "Understands dereference assignment writes through the pointer"
          ]
        },
        {
          "question_id": "d7",
          "subskill_id": "c_ptr_arithmetic",
          "type": "mcq",
          "difficulty": 2,
          "prompt": "Assume sizeof(int)=4. If `int *p` holds address 1000, what address after `p++`?",
          "choices": [
            "1001",
            "1002",
            "1004",
            "1016"
          ],
          "correct_answer": "1004",
          "rubric": [
            "Pointer arithmetic is scaled by sizeof(*p)"
          ]
        },
        {
          "question_id": "d8",
          "subskill_id": "c_ptr_arithmetic",
          "type": "mcq",
          "difficulty": 2,
          "prompt": "Which statement about pointer arithmetic is correct?",
          "choices": [
            "p++ always adds 1 byte",
            "p++ adds sizeof(*p) bytes",
            "p++ is only valid for char*",
            "p++ changes the value stored at *p"
          ],
          "correct_answer": "p++ adds sizeof(*p) bytes",
          "rubric": [
            "Knows pointer increment moves the pointer, scaled by type"
          ]
        }
      ],
